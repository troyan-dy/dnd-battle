# .env.example — copy to `.env` and adjust for local dev. NEVER commit real `.env`.
# These are non-secret placeholder defaults safe for local development only.

# --- Postgres (used by docker-compose and the backend) ---
POSTGRES_USER=dnd
POSTGRES_PASSWORD=dnd
POSTGRES_DB=dnd_battle
# Host port mapped to the Postgres container (container always listens on 5432).
POSTGRES_PORT=5432

# Async SQLAlchemy connection string (asyncpg driver). Host is `localhost` when
# the backend runs on the host machine against the docker-compose Postgres.
DATABASE_URL=postgresql+asyncpg://dnd:dnd@localhost:5432/dnd_battle

# --- Redis (OPTIONAL — only when scaling past one server process) ---
# Start it with:  docker compose --profile cache up
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379/0
